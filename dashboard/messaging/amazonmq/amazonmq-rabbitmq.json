{
  "title": "AmazonMQ RabbitMQ",
  "uid": "amazonmq-rabbitmq-yace-v1",
  "description": "AmazonMQ RabbitMQ broker and per-queue metrics via YACE (yet-another-cloudwatch-exporter). Source: CloudWatch AWS/AmazonMQ namespace.",
  "tags": [
    "amazonmq",
    "rabbitmq",
    "aws",
    "cloudwatch",
    "messaging"
  ],
  "timezone": "browser",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "refresh": "5m",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "current": {
          "selected": true,
          "text": "default",
          "value": "default"
        },
        "label": "Data source",
        "name": "datasource",
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "name": "broker",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": {
          "query": "label_values(aws_amazonmq_message_count_average, dimension_Broker)",
          "refId": "A"
        },
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "label": "Broker"
      },
      {
        "name": "queue",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": {
          "query": "label_values(aws_amazonmq_message_ready_count_maximum{dimension_Broker=~\"$broker\", dimension_Queue!=\"\"}, dimension_Queue)",
          "refId": "A"
        },
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": false,
        "label": "Queue"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Broker Overview",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Messages",
      "description": "Total messages across all queues on this broker (CloudWatch broker-level aggregate).",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "aws_amazonmq_message_count_average{dimension_Broker=~\"$broker\", dimension_Queue=\"\"}",
          "legendFormat": "Messages",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100000
              },
              {
                "color": "red",
                "value": 500000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Ready Messages (Max)",
      "description": "Peak ready (queued, undelivered) messages. Alerts fire at 10k (warning) and 100k (critical).",
      "gridPos": {
        "x": 6,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "aws_amazonmq_message_ready_count_maximum{dimension_Broker=~\"$broker\", dimension_Queue=\"\"}",
          "legendFormat": "Ready",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10000
              },
              {
                "color": "red",
                "value": 100000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Unacknowledged Messages",
      "description": "Messages delivered to consumers but not yet acked. High values indicate slow/stuck consumers.",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "aws_amazonmq_message_unacknowledged_count_average{dimension_Broker=~\"$broker\", dimension_Queue=\"\"}",
          "legendFormat": "Unacked",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "red",
                "value": 10000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Consumers",
      "description": "Number of active consumer connections on this broker.",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "aws_amazonmq_consumer_count_average{dimension_Broker=~\"$broker\", dimension_Queue=\"\"}",
          "legendFormat": "Consumers",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 10
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Broker Message Count",
      "description": "Total message count trend across the entire broker (all queues aggregated by CloudWatch).",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "aws_amazonmq_message_count_average{dimension_Broker=~\"$broker\", dimension_Queue=\"\"}",
          "legendFormat": "Total (avg)",
          "refId": "A"
        },
        {
          "expr": "aws_amazonmq_message_count_maximum{dimension_Broker=~\"$broker\", dimension_Queue=\"\"}",
          "legendFormat": "Total (max)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Broker Consumer Count",
      "description": "Total consumer count on the broker over time.",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "aws_amazonmq_consumer_count_average{dimension_Broker=~\"$broker\", dimension_Queue=\"\"}",
          "legendFormat": "Consumers",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "mean",
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Queue Backlog \u2014 Top 20",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Top 20 Queues by Ready Messages",
      "description": "Queues with highest message backlog (ready/undelivered). Filtered by $broker. Alert threshold: 10k warning, 100k critical.",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "topk(20, aws_amazonmq_message_ready_count_maximum{dimension_Broker=~\"$broker\", dimension_Queue!=\"\"})",
          "legendFormat": "{{dimension_Queue}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10000
              },
              {
                "color": "red",
                "value": 100000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true,
        "valueMode": "color"
      }
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Top 20 Queues by Unacknowledged Messages",
      "description": "Queues with most unacked messages \u2014 indicates slow or stuck consumers.",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "topk(20, aws_amazonmq_message_unacknowledged_count_maximum{dimension_Broker=~\"$broker\", dimension_Queue!=\"\"})",
          "legendFormat": "{{dimension_Queue}}",
          "refId": "A",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000
              },
              {
                "color": "red",
                "value": 10000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true,
        "valueMode": "color"
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Per-Queue Detail",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Ready Messages per Queue",
      "description": "Per-queue ready (undelivered) message count over time. Use $queue variable to filter. Showing top 20 by value. Use $queue variable to filter specific queues.",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 12,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "topk(20, aws_amazonmq_message_ready_count_maximum{dimension_Broker=~\"$broker\", dimension_Queue!=\"\"})",
          "legendFormat": "{{dimension_Queue}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10000
              },
              {
                "color": "red",
                "value": 100000
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Unacknowledged Messages per Queue",
      "description": "Per-queue unacked messages over time. Sustained high values = slow/stuck consumer. Showing top 20 by value. Use $queue variable to filter specific queues.",
      "gridPos": {
        "x": 12,
        "y": 37,
        "w": 12,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "topk(20, aws_amazonmq_message_unacknowledged_count_average{dimension_Broker=~\"$broker\", dimension_Queue!=\"\"})",
          "legendFormat": "{{dimension_Queue}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "max",
            "last"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Consumer Count per Queue",
      "description": "Number of consumers per queue. Zero consumers with queued messages = alert condition. Showing top 20 by value. Use $queue variable to filter specific queues.",
      "gridPos": {
        "x": 0,
        "y": 46,
        "w": 12,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "topk(20, aws_amazonmq_consumer_count_average{dimension_Broker=~\"$broker\", dimension_Queue!=\"\"})",
          "legendFormat": "{{dimension_Queue}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 5
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "min",
            "last"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "asc"
        }
      }
    },
    {
      "id": 24,
      "type": "table",
      "title": "Queues with Zero Consumers (+ Backlog > 100)",
      "description": "Queues that have messages waiting but no active consumers \u2014 highest risk for message accumulation.",
      "gridPos": {
        "x": 12,
        "y": 46,
        "w": 12,
        "h": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "aws_amazonmq_consumer_count_average{dimension_Broker=~\"$broker\", dimension_Queue!=\"\"} == 0",
          "legendFormat": "{{dimension_Queue}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "aws_amazonmq_message_ready_count_maximum{dimension_Broker=~\"$broker\", dimension_Queue!=\"\"} > 100",
          "legendFormat": "{{dimension_Queue}}",
          "refId": "B",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "dimension_Queue": "Queue",
              "dimension_Broker": "Broker",
              "dimension_VirtualHost": "VHost",
              "Value #A": "Consumers",
              "Value #B": "Ready Messages"
            },
            "excludeByName": {
              "Time": true,
              "account_alias": true,
              "account_id": true,
              "region": true,
              "name": true,
              "tag_Environment": true,
              "tag_Name": true
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": [
              {
                "desc": true,
                "displayName": "Ready Messages"
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Consumers"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": null
                    },
                    {
                      "color": "green",
                      "value": 1
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Ready Messages"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 10000
                    },
                    {
                      "color": "red",
                      "value": 100000
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "desc": true,
            "displayName": "Ready Messages"
          }
        ]
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "YACE Exporter Health",
      "collapsed": true,
      "gridPos": {
        "x": 0,
        "y": 55,
        "w": 24,
        "h": 1
      },
      "panels": [
        {
          "id": 31,
          "type": "stat",
          "title": "YACE Up",
          "description": "Whether the YACE exporter is reachable and scraping successfully.",
          "gridPos": {
            "x": 0,
            "y": 56,
            "w": 6,
            "h": 4
          },
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "targets": [
            {
              "expr": "up{job=~\".*yace.*\"}",
              "legendFormat": "YACE",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "mappings": [
                {
                  "options": {
                    "0": {
                      "text": "DOWN",
                      "color": "red"
                    },
                    "1": {
                      "text": "UP",
                      "color": "green"
                    }
                  },
                  "type": "value"
                }
              ],
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "red",
                    "value": null
                  },
                  {
                    "color": "green",
                    "value": 1
                  }
                ]
              }
            },
            "overrides": []
          },
          "options": {
            "reduceOptions": {
              "calcs": [
                "lastNotNull"
              ]
            },
            "colorMode": "background",
            "textMode": "auto",
            "graphMode": "none"
          }
        },
        {
          "id": 32,
          "type": "stat",
          "title": "Metrics Scraped Total",
          "description": "Total number of CloudWatch metrics requested via GetMetricData API.",
          "gridPos": {
            "x": 6,
            "y": 56,
            "w": 6,
            "h": 4
          },
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "targets": [
            {
              "expr": "yace_cloudwatch_getmetricdata_metrics_requested_total",
              "legendFormat": "Metrics",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "short"
            },
            "overrides": []
          },
          "options": {
            "reduceOptions": {
              "calcs": [
                "lastNotNull"
              ]
            },
            "colorMode": "value",
            "graphMode": "area"
          }
        },
        {
          "id": 33,
          "type": "timeseries",
          "title": "CloudWatch API Call Rate",
          "description": "Rate of CloudWatch API calls by API type. High ListMetrics/GetMetricData rates = cost driver.",
          "gridPos": {
            "x": 12,
            "y": 56,
            "w": 12,
            "h": 8
          },
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "targets": [
            {
              "expr": "rate(yace_cloudwatch_requests_total[5m])",
              "legendFormat": "{{api_name}}",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "unit": "reqps",
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "options": {
            "legend": {
              "calcs": [
                "mean",
                "max"
              ],
              "displayMode": "table",
              "placement": "bottom"
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          }
        }
      ]
    }
  ]
}